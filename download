GOTHIC = "YuGothic"
GOTHIC_BOLD = "YuGothicBold"
MINCHO_BOLD = "YuMinchoBold"


def register_fonts() -> None:
    pdfmetrics.registerFont(TTFont(GOTHIC, "C:/Windows/Fonts/YuGothR.ttc", subfontIndex=0))
    pdfmetrics.registerFont(TTFont(GOTHIC_BOLD, "C:/Windows/Fonts/YuGothB.ttc", subfontIndex=0))
    pdfmetrics.registerFont(TTFont(MINCHO_BOLD, "C:/Windows/Fonts/yumindb.ttf"))


def paragraph_style(size: float, leading: float, color=TEXT, font=GOTHIC, align=0) -> ParagraphStyle:
    return ParagraphStyle(
        name=f"style-{size}-{leading}-{font}-{align}",
        fontName=font,
        fontSize=size,
        leading=leading,
        textColor=color,
        alignment=align,
        wordWrap="CJK",
        spaceAfter=0,
        spaceBefore=0,
    )


def clean(text: str) -> str:
    return escape(text).replace("\n", "<br/>")


def draw_paragraph(c: canvas.Canvas, text: str, x: float, top: float, width: float, style: ParagraphStyle) -> float:
    paragraph = Paragraph(clean(text), style)
    _, height = paragraph.wrap(width, 1000)
    paragraph.drawOn(c, x, top - height)
    return height


def round_box(
    c: canvas.Canvas,
    x: float,
    y: float,
    w: float,
    h: float,
    fill=WHITE,
    stroke=LINE,
    radius: float = 12,
    line_width: float = 0.8,
) -> None:
    c.setFillColor(fill)
    c.setStrokeColor(stroke)
    c.setLineWidth(line_width)
    c.roundRect(x, y, w, h, radius, stroke=1, fill=1)


def shadow_box(c: canvas.Canvas, x: float, y: float, w: float, h: float, radius: float = 12) -> None:
    c.setFillColor(colors.Color(0.05, 0.10, 0.12, alpha=0.08))
    c.roundRect(x + 2.8, y - 3.2, w, h, radius, stroke=0, fill=1)


def label(c: canvas.Canvas, text: str, x: float, y: float, fill=GOLD, text_color=WHITE) -> None:
    width = pdfmetrics.stringWidth(text, GOTHIC_BOLD, 7.4) + 18
    c.setFillColor(fill)
    c.roundRect(x, y, width, 18, 9, stroke=0, fill=1)
    c.setFillColor(text_color)
    c.setFont(GOTHIC_BOLD, 7.4)
    c.drawCentredString(x + width / 2, y + 5.3, text)


def section_heading(c: canvas.Canvas, x: float, y: float, small: str, title: str) -> None:
    c.setFillColor(GOLD)
    c.roundRect(x, y - 4, 5, 27, 2.5, stroke=0, fill=1)
    c.setFillColor(MUTED)
    c.setFont(GOTHIC_BOLD, 7.5)
    c.drawString(x + 14, y + 13, small)
    c.setFillColor(INK)
    c.setFont(GOTHIC_BOLD, 15.5)
    c.drawString(x + 14, y - 8, title)


def mini_line(c: canvas.Canvas, x: float, y: float, w: float, color=LINE, height: float = 3.4) -> None:
    c.setFillColor(color)
    c.roundRect(x, y, w, height, height / 2, stroke=0, fill=1)


def draw_mock_card(c: canvas.Canvas, x: float, y: float, w: float, h: float, title: str, accent, lines: list[float]) -> None:
    shadow_box(c, x, y, w, h, 10)
    round_box(c, x, y, w, h, WHITE, colors.Color(1, 1, 1, alpha=0.55), 10, 0.4)
    c.setFillColor(accent)
    c.roundRect(x + 12, y + h - 27, 42, 14, 7, stroke=0, fill=1)
    c.setFillColor(WHITE)
    c.setFont(GOTHIC_BOLD, 6.3)
    c.drawCentredString(x + 33, y + h - 22.5, "AI案")
    c.setFillColor(INK)
    c.setFont(GOTHIC_BOLD, 8.1)
    c.drawString(x + 62, y + h - 23, title)
    yy = y + h - 44
    for line_width in lines:
        mini_line(c, x + 14, yy, line_width, colors.HexColor("#DCE6EA"), 3.1)
        yy -= 10


