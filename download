    x = MARGIN
    y = 254
    w = PAGE_W - MARGIN * 2
    h = 133
    round_box(c, x, y, w, h, WHITE, colors.HexColor("#E1EAED"), 16)

    steps = [
        (
            "01",
            "AI業務改善診断",
            "今の業務をヒアリングし、AIで軽くできる業務と優先順位を整理します。",
            "予約対応 / LINE返信 / SNS投稿 / 口コミ返信",
        ),
        (
            "02",
            "店舗専用テンプレート",
            "客層、メニュー、価格帯、接客方針に合わせて文章の型を作ります。",
            "返信文 / 投稿文 / 告知文 / 求人文 / フォロー文",
        ),
        (
            "03",
            "使い方レクチャーと定着",
            "オーナーやスタッフが自分で使えるよう説明し、運用後に改善します。",
            "簡易マニュアル / 改善ミーティング / 更新支援",
        ),
    ]
    col_w = w / 3
    for i, (num, title, body, tags) in enumerate(steps):
        cx = x + col_w * i
        if i > 0:
            c.setStrokeColor(colors.HexColor("#DCE6EA"))
            c.line(cx, y + 20, cx, y + h - 20)
        c.setFillColor(TEAL if i != 1 else BLUE)
        c.roundRect(cx + 18, y + h - 48, 34, 34, 17, stroke=0, fill=1)
        c.setFillColor(WHITE)
        c.setFont(GOTHIC_BOLD, 9.4)
        c.drawCentredString(cx + 35, y + h - 28, num)
        c.setFillColor(INK)
        c.setFont(GOTHIC_BOLD, 10.3)
        c.drawString(cx + 62, y + h - 26, title)
        draw_paragraph(c, body, cx + 18, y + h - 62, col_w - 36, paragraph_style(7.4, 11.2, TEXT))
        c.setFillColor(MUTED)
        c.setFont(GOTHIC_BOLD, 6.7)
        c.drawString(cx + 18, y + 23, tags)


def draw_flow(c: canvas.Canvas) -> None:
    x = MARGIN
    y = 196
    w = 338
    round_box(c, x, y, w, 44, TEAL_SOFT, colors.HexColor("#CDE0DB"), 17)
    c.setFillColor(TEAL)
    c.setFont(GOTHIC_BOLD, 9)
    c.drawString(x + 18, y + 24, "ご依頼")
    c.drawString(x + 18, y + 12, "から導入")
    steps = ["メール相談", "日程調整", "ヒアリング", "提案", "導入"]
    start_x = x + 92
    gap = 54
    for i, step in enumerate(steps):
        sx = start_x + i * gap
        c.setFillColor(WHITE)
        c.circle(sx, y + 25, 8.4, stroke=0, fill=1)
        c.setStrokeColor(GOLD)
        c.circle(sx, y + 25, 8.4, stroke=1, fill=0)
        c.setFillColor(GOLD)
        c.setFont(GOTHIC_BOLD, 6.5)
        c.drawCentredString(sx, y + 22.7, str(i + 1))
        c.setFillColor(INK)
        c.setFont(GOTHIC_BOLD, 6.4)
        c.drawCentredString(sx, y + 8, step)
        if i < len(steps) - 1:
            c.setStrokeColor(colors.HexColor("#B9CBC7"))
            c.line(sx + 11, y + 25, sx + gap - 11, y + 25)

    ox = x + w + 13
    ow = PAGE_W - MARGIN - ox
    round_box(c, ox, y, ow, 44, TEAL_DARK, TEAL_DARK, 17)
    c.setFillColor(GOLD)
    c.setFont(GOTHIC_BOLD, 6.4)
    c.drawString(ox + 14, y + 28, "CONTACT")
    c.setFillColor(WHITE)
    c.setFont(GOTHIC_BOLD, 9.7)
    c.drawString(ox + 14, y + 14, "メールで相談・依頼")
    c.setFillColor(colors.Color(1, 1, 1, alpha=0.72))
    c.setFont(GOTHIC, 6.3)
    c.drawString(ox + 14, y + 5, CONTACT_EMAIL)


def draw_pricing(c: canvas.Canvas) -> None:
    section_heading(c, MARGIN, 160, "PLAN", "料金プラン")

    x = MARGIN
    y = 54
    w = PAGE_W - MARGIN * 2
    h = 89
    plan_gap = 9
    plan_w = (w - plan_gap * 2) / 3
    plans = [
        ("AI業務改善診断", "50,000円〜", "90分ヒアリング / 業務洗い出し\nテンプレート3点"),
        ("AI右腕導入パック", "100,000円〜", "専用テンプレート / LINE/SNS/口コミ\n簡易マニュアル"),
        ("継続サポート", "月額30,000円〜", "月1回改善 / テンプレート更新\n文章作成支援"),
    ]
    for i, (title, price, body) in enumerate(plans):
        px = x + i * (plan_w + plan_gap)
        fill = WHITE if i != 1 else CREAM
        stroke = colors.HexColor("#DDE6E9") if i != 1 else colors.HexColor("#D4B06B")
        shadow_box(c, px, y, plan_w, h, 13)
        round_box(c, px, y, plan_w, h, fill, stroke, 13)
        if i == 1:
            c.setFillColor(GOLD)
            c.roundRect(px + 13, y + h - 20, 47, 13, 6.5, stroke=0, fill=1)
            c.setFillColor(WHITE)
            c.setFont(GOTHIC_BOLD, 6.2)
            c.drawCentredString(px + 36.5, y + h - 16.2, "おすすめ")
        c.setFillColor(INK)
        c.setFont(GOTHIC_BOLD, 9.3)
        c.drawString(px + 13, y + h - 34, title)
        c.setFillColor(GOLD if i == 1 else TEAL)
        c.setFont(GOTHIC_BOLD, 13.2)
        c.drawString(px + 13, y + h - 55, price)
        draw_paragraph(c, body, px + 13, y + 30, plan_w - 26, paragraph_style(6.4, 8.5, MUTED))

    c.setFillColor(MUTED)
    c.setFont(GOTHIC, 6.3)
    c.drawString(MARGIN, 44, "※ 表示価格は目安です。支援範囲、店舗数、テンプレート数に応じて個別にお見積もりします。")


def draw_footer(c: canvas.Canvas) -> None:
    c.setFillColor(TEAL_DARK)
    c.rect(0, 0, PAGE_W, 34, stroke=0, fill=1)
    c.setFillColor(WHITE)
    c.setFont(GOTHIC_BOLD, 7.4)
    c.drawString(MARGIN, 19, f"ご依頼方法：{CONTACT_EMAIL} へ「店舗名・相談内容・希望時期」を送付")
    c.setFillColor(colors.Color(1, 1, 1, alpha=0.66))
    c.setFont(GOTHIC, 6.3)
    c.drawString(MARGIN, 8, "対象例：美容室、サロン、整体、クリニック、スクール、物販店、地域サービス店など")
    c.setFillColor(GOLD)
    c.setFont(GOTHIC_BOLD, 6.7)
    c.drawRightString(PAGE_W - MARGIN, 13, "小規模店舗向け AI右腕導入サポート")


def build_pdf() -> Path:
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    register_fonts()
    c = canvas.Canvas(str(OUTPUT_FILE), pagesize=A4, pageCompression=1)
    c.setTitle("小規模店舗向け AI右腕導入サポート A4資料")
    c.setAuthor("FUYOU LLC")
    draw_hero(c)
    draw_problem_strip(c)
    draw_support(c)
    draw_flow(c)
    draw_pricing(c)
    draw_footer(c)
    c.showPage()
    c.save()
    return OUTPUT_FILE


if __name__ == "__main__":
    print(build_pdf())
