def draw_problem_strip(c: canvas.Canvas) -> None:
    x = MARGIN
    y = 470
    w = PAGE_W - MARGIN * 2
    h = 96
    shadow_box(c, x, y, w, h, 16)
    round_box(c, x, y, w, h, WHITE, colors.HexColor("#E1EAED"), 16)

    c.setFillColor(TEAL)
    c.setFont(GOTHIC_BOLD, 13.5)
    c.drawString(x + 22, y + h - 34, "毎日のこの負担を減らします")

    items = [
        ("返信", "時間がかかる"),
        ("投稿", "続かない"),
        ("口コミ", "後回し"),
        ("告知文", "考えるのが重い"),
    ]
    item_w = (w - 48) / 4
    for i, (title, body) in enumerate(items):
        ix = x + 22 + i * item_w
        c.setFillColor(TEAL_SOFT if i % 2 == 0 else CREAM)
        c.roundRect(ix, y + 12, item_w - 8, 30, 9, stroke=0, fill=1)
        c.setFillColor(TEAL if i % 2 == 0 else GOLD)
        c.setFont(GOTHIC_BOLD, 7.1)
        c.drawString(ix + 10, y + 30, title)
        c.setFillColor(INK)
        c.setFont(GOTHIC_BOLD, 8.3)
        c.drawString(ix + 10, y + 18, body)


def draw_support(c: canvas.Canvas) -> None:
