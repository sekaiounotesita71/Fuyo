    c.drawString(visual_x + 18, visual_y + 143, "そのまま使える文章の型")
    draw_mock_card(c, visual_x + 18, visual_y + 91, 128, 42, "LINE返信", GOLD, [84, 68, 92])
    draw_mock_card(c, visual_x + 27, visual_y + 45, 128, 42, "SNS投稿", BLUE, [75, 88, 54])
