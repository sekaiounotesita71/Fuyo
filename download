    c.roundRect(visual_x, visual_y, 164, 191, 18, stroke=0, fill=1)
    c.setStrokeColor(colors.Color(1, 1, 1, alpha=0.22))
    c.setLineWidth(0.8)
    c.roundRect(visual_x, visual_y, 164, 191, 18, stroke=1, fill=0)

    c.setFillColor(WHITE)
    c.setFont(GOTHIC_BOLD, 12.5)
    c.drawString(visual_x + 18, visual_y + 159, "AI右腕で作るもの")
    c.setFillColor(colors.Color(1, 1, 1, alpha=0.68))
